SERVER_HOST=0.0.0.0
SERVER_PORT=8000
CAMERA_IDS=camera_01,camera_02,camera_03
VISUALIZE_METRICS=true

# --- LLM (이구동성 게임 MC/제시어/리포트) ---
# 끄면 정적 텍스트로 폴백하므로 게임은 그대로 동작한다.
LLM_ENABLED=false
# Ollama OpenAI 호환 엔드포인트. LLM 전용 보드면 http://<pi-ip>:11434/v1/chat/completions
LLM_BASE_URL=http://127.0.0.1:11434/v1/chat/completions
LLM_MODEL=exaone3.5:2.4b
LLM_TIMEOUT=12
LLM_DEFAULT_THEME=기본

# --- TTS (AI MC 음성 출력, 스피커가 달린 서버 보드에서 재생) ---
# result/finished/시작 인트로 구간에서만 백그라운드로 재생 → playing 성능에 영향 없음.
# 끄면 음성 없이 화면 멘트만 나온다.
TTS_ENABLED=false
# auto | openai | piper | espeak  (auto: 사용 가능한 것 중 품질 높은 순으로 자동 선택)
TTS_ENGINE=auto
# OpenAI TTS voice (coral/nova/shimmer 등). OPENAI_API_KEY 환경변수 필요.
TTS_VOICE=coral
TTS_OPENAI_MODEL=gpt-4o-mini-tts
# Piper 사용 시 .onnx 모델 경로 (예: /home/willtek/piper/ko_KR-voice.onnx)
TTS_PIPER_MODEL=
TTS_LANG=ko
# 인트로 멘트용 (비우면 "여러분"). AI MC 이름.
TTS_TEAM_NAME=
TTS_MC_NAME=민수

# --- 브라우저 재생용 자연스러운 음성 (edge-tts, 무료 신경망 보이스) ---
# 서버에서 음성을 생성해 브라우저(노트북/헤드폰)로 재생한다. 인터넷 필요.
# 보드 스피커 없이도 자연스러운 한국어 목소리를 들을 수 있다.
# 끄거나 edge-tts 미설치 시 브라우저 기본 음성(Web Speech)으로 자동 폴백.
EDGE_TTS_ENABLED=true
# 추천: ko-KR-InJoonNeural(남), ko-KR-SunHiNeural(여)
EDGE_TTS_VOICE=ko-KR-InJoonNeural
# 말 빠르기 (예: +8%, -10%)
EDGE_TTS_RATE=+22%



